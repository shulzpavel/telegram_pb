APP_DOMAIN=planning.shults-sync.com
ACME_EMAIL=admin@shults-sync.com

# Site-wide IP allowlist (Caddy). Everyone using Planning Poker must connect
# from these networks (corporate VPN). Space-separated list of IPs or CIDRs.
# Example: SITE_ALLOWED_IPS=203.0.113.10 198.51.100.0/24 10.8.0.0/24
SITE_ALLOWED_IPS=
SITE_IP_WHITELIST_ENABLED=true

POSTGRES_DB=planning_poker
POSTGRES_USER=planning_poker
POSTGRES_PASSWORD=change-me-long-random

CMS_USERNAME=admin
CMS_PASSWORD=change-me-long-random

JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
STORY_POINTS_FIELD=customfield_10022
JIRA_FRONT_ASSIGNEE_FIELD=customfield_10710
JIRA_BACK_ASSIGNEE_FIELD=customfield_10711
JIRA_QA_ASSIGNEE_FIELD=customfield_10249
JIRA_DEMO_FALLBACK=false
JIRA_CACHE_MAX_ITEMS=1000

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_SECONDS=20
ANTHROPIC_MAX_CONTEXT_CHARS=16000
JIRA_UPDATE_CONCURRENCY=5
JIRA_SERVICE_TIMEOUT_SECONDS=30

CORS_ORIGINS=https://planning.shults-sync.com
JIRA_SERVICE_CORS_ORIGINS=https://planning.shults-sync.com
ENABLE_DEMO_SESSION=false

# Session-finish Telegram alerts (same bot/chat as pipeline deploy notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEB_UI_URL=https://planning.shults-sync.com

# Web join: corporate email domain for participants (default betboom.com)
# WEB_PARTICIPANT_EMAIL_DOMAIN=betboom.com
